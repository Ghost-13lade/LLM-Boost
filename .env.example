# LLM Boost Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Backend Selection
# ===========================================
# Choose which LLM backend to use: 'network' or 'mlx'
LLM_BACKEND=network

# ===========================================
# Model Configuration
# ===========================================
# Model path or name (used by both backends)
# For network: model name like 'gpt-4', 'claude-3-opus', etc.
# For MLX: HuggingFace model ID like 'mlx-community/Mistral-7B-Instruct-v0.3-4bit'
MODEL_PATH=gpt-4

# Generation settings
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096

# ===========================================
# Network Provider Settings
# ===========================================
# API Key for the LLM service
API_KEY=your_api_key_here

# Base URL for API endpoint (optional)
# Leave empty for OpenAI default
# For LM Studio: http://localhost:1234/v1
# For Ollama: http://localhost:11434/v1
# For vLLM: http://localhost:8000/v1
API_BASE_URL=

# ===========================================
# MLX Provider Settings (Apple Silicon)
# ===========================================
# Local path to MLX model (optional, can use MODEL_PATH instead)
# MLX_MODEL_PATH=./models/

# ===========================================
# Memory Settings
# ===========================================
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/memory.db

# ===========================================
# Legacy Variables (for backward compatibility)
# ===========================================
# These are still supported but prefer the new variables above
# OPENAI_API_KEY=your_openai_api_key_here
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# DEFAULT_MODEL=gpt-4